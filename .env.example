# Environment Variables Template
# Copy this file to .env and fill in the actual values
# DO NOT commit .env to git (it contains secrets)

# Bybit Testnet API Keys
# Get your keys from: https://testnet.bybit.com/app/apikey
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Trading Environment (DO NOT change to mainnet without explicit override)
TRADING_ENV=testnet

# Risk Limits (optional overrides)
# RISK_MAX_POSITION_BTC=1.0
# RISK_MAX_DAILY_LOSS_PCT=0.05

# Execution Configuration (optional overrides)
# EXECUTION_FEE_RATE_PCT=0.1
