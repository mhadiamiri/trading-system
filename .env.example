# Environment Variables Template
# Copy this file to .env and fill in the actual values
# DO NOT commit .env to git (it contains secrets)

# Data Source Configuration
# Selects the market data feed (independent of execution environment)
# Options: simulated, kraken_public
# - simulated: Mock market data for testing
# - kraken_public: Live mainnet public data (read-only, no credentials needed)
DATA_SOURCE=simulated

# Trading Environment Configuration
# Gates execution only (not data access)
# Options: paper, mainnet
# - paper: Simulated execution (safe, no real money)
# - mainnet: Real-money execution (requires explicit, deliberate override)
TRADING_ENV=paper

# Risk Limits (optional overrides)
# RISK_MAX_POSITION_BTC=1.0
# RISK_MAX_DAILY_LOSS_PCT=0.05

# Execution Configuration (optional overrides)
# EXECUTION_FEE_RATE_PCT=0.1

# Data Persistence (optional overrides)
# DATA_DIR=data
# LOG_DIR=logs

